@model VendorMasterFormViewModel

@{
    ViewData["Title"] = "Add Vendor";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Add Vendor</h1>
        <p class="text-muted mb-0">Create an approved payee for payment requests.</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Back to List
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post" asp-antiforgery="true">
            <partial name="_VendorMasterFields" model="Model" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Save Vendor
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}