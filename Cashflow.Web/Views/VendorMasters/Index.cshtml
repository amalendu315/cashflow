@model VendorMasterIndexViewModel

@{
    ViewData["Title"] = "Vendor Master";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Vendor Master</h1>
        <p class="text-muted mb-0">Manage approved payees for payment requests.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Add Vendor
    </a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Total Vendors</div>
                <div class="fs-4 fw-semibold">@Model.TotalCount</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Active</div>
                <div class="fs-4 fw-semibold">@Model.ActiveCount</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Inactive</div>
                <div class="fs-4 fw-semibold">@Model.InactiveCount</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Vendors.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <h2 class="h5">No vendors added yet</h2>
            <p class="text-muted mb-3">Create your first approved vendor or payee.</p>
            <a asp-action="Create" class="btn btn-primary">Add Vendor</a>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Vendor Name</th>
                    <th>GST Number</th>
                    <th>Status</th>
                    <th>Requests</th>
                    <th>Created UTC</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (VendorMasterListItemViewModel vendor in Model.Vendors)
                {
                    <tr>
                        <td class="fw-semibold font-monospace">@vendor.VendorCode</td>
                        <td>@vendor.VendorName</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(vendor.GstNumber))
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <span class="font-monospace">@vendor.GstNumber</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(vendor.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                @(vendor.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>@vendor.PaymentRequestCount</td>
                        <td>@vendor.CreatedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</td>
                        <td class="text-end">
                            <a asp-action="Edit"
                               asp-route-id="@vendor.Id"
                               class="btn btn-sm btn-outline-light">
                                Edit
                            </a>

                            @if (vendor.IsActive)
                            {
                                <form asp-action="Deactivate"
                                      asp-route-id="@vendor.Id"
                                      method="post"
                                      asp-antiforgery="true"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        Deactivate
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Activate"
                                      asp-route-id="@vendor.Id"
                                      method="post"
                                      asp-antiforgery="true"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        Activate
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}