@model LedgerReportIndexViewModel

@{
    ViewData["Title"] = "Ledger Report";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Ledger Report</h1>
        <p class="text-muted mb-0">View ledger entries across a selected IST date range.</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Daily Balance
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Report" method="get" class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label asp-for="LedgerMasterId" class="form-label"></label>
                <select asp-for="LedgerMasterId"
                        asp-items="Model.LedgerOptions"
                        class="form-select">
                    <option value="">Select ledger</option>
                </select>
            </div>

            <div class="col-lg-3">
                <label asp-for="FromDate" class="form-label"></label>
                <input asp-for="FromDate" class="form-control" type="date" />
            </div>

            <div class="col-lg-3">
                <label asp-for="ToDate" class="form-label"></label>
                <input asp-for="ToDate" class="form-control" type="date" />
            </div>

            <div class="col-lg-2">
                <button type="submit" class="btn btn-primary w-100">
                    Load Report
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.HasDateError)
{
    <div class="alert alert-danger" role="alert">
        From Date cannot be greater than To Date.
    </div>
}
else if (!Model.HasLedgerSelected)
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <h2 class="h5">Select a ledger</h2>
            <p class="text-muted mb-0">Choose a ledger and date range to view report entries.</p>
        </div>
    </div>
}
else
{
    <div class="mb-4">
        <h2 class="h5 mb-1">@Model.LedgerDisplay</h2>
        <p class="text-muted mb-0">@Model.DateRangeDisplay</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Opening Total</div>
                    <div class="fs-5 fw-semibold font-monospace">@Model.OpeningBalanceTotalDisplay</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Inflow Total</div>
                    <div class="fs-5 fw-semibold font-monospace">@Model.InflowTotalDisplay</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Outflow Total</div>
                    <div class="fs-5 fw-semibold font-monospace">@Model.OutflowTotalDisplay</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Range Balance Effect</div>
                    <div class="fs-5 fw-semibold font-monospace">@Model.RangeBalanceEffectDisplay</div>
                    <div class="small text-muted">Opening + Inflow - Outflow</div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.HasEntries)
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <h2 class="h5">No entries found</h2>
                <p class="text-muted mb-0">No ledger entries exist for this ledger and date range.</p>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Payment Request</th>
                        <th>Description</th>
                        <th>Created By</th>
                        <th>Created IST</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (LedgerReportEntryViewModel entry in Model.Entries)
                    {
                        <tr>
                            <td>@entry.EntryDateDisplay</td>
                            <td>
                                <span class="badge @entry.EntryTypeBadgeClass">
                                    @entry.EntryType
                                </span>
                            </td>
                            <td class="font-monospace">@entry.AmountDisplay</td>
                            <td class="font-monospace">
                                @if (entry.PaymentRequestId.HasValue)
                                {
                                    <a asp-controller="AdminPaymentRequests"
                                       asp-action="Review"
                                       asp-route-id="@entry.PaymentRequestId.Value"
                                       class="link-info">
                                        @entry.PaymentRequestDisplay
                                    </a>
                                }
                                else
                                {
                                    @entry.PaymentRequestDisplay
                                }
                            </td>
                            <td>@entry.DescriptionDisplay</td>
                            <td>
                                <div>@entry.CreatedByName</div>
                                <div class="small text-muted">@entry.CreatedByEmail</div>
                            </td>
                            <td>@entry.CreatedAtDisplay</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}