@model CompanyMasterFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="mb-3">
    <label asp-for="CompanyCode" class="form-label"></label>
    <input asp-for="CompanyCode" class="form-control" autocomplete="off" />
    <span asp-validation-for="CompanyCode" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CompanyName" class="form-label"></label>
    <input asp-for="CompanyName" class="form-control" autocomplete="off" />
    <span asp-validation-for="CompanyName" class="text-danger"></span>
</div>

<div class="form-check form-switch mb-3">
    <input asp-for="IsActive" class="form-check-input" />
    <label asp-for="IsActive" class="form-check-label"></label>
</div>