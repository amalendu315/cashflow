@model SubsidiaryUserCreateViewModel

@{
    ViewData["Title"] = "Add User";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Add Subsidiary User</h1>
        <p class="text-muted mb-0">Create a user and assign them to a company.</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Back to List
    </a>
</div>

@if (!Model.CompanyOptions.Any())
{
    <div class="alert alert-warning" role="alert">
        No active companies are available. Create or activate a company before adding users.
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post" asp-antiforgery="true">
            <partial name="_SubsidiaryUserFields" model="Model" />

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary"
                        disabled="@(!Model.CompanyOptions.Any())">
                    Save User
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}