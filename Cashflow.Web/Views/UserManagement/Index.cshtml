@model SubsidiaryUserIndexViewModel

@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">User Management</h1>
        <p class="text-muted mb-0">Manage subsidiary users and company access.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Add User
    </a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Total Users</div>
                <div class="fs-4 fw-semibold">@Model.TotalCount</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Active</div>
                <div class="fs-4 fw-semibold">@Model.ActiveCount</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Inactive</div>
                <div class="fs-4 fw-semibold">@Model.InactiveCount</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Users.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <h2 class="h5">No subsidiary users added yet</h2>
            <p class="text-muted mb-3">Create users after adding active companies.</p>
            <a asp-action="Create" class="btn btn-primary">Add User</a>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Company</th>
                    <th>Status</th>
                    <th>Created UTC</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (SubsidiaryUserListItemViewModel user in Model.Users)
                {
                    <tr>
                        <td class="fw-semibold">@user.FullName</td>
                        <td>@user.Email</td>
                        <td>
                            <div>@user.CompanyName</div>
                            @if (!string.IsNullOrWhiteSpace(user.CompanyCode))
                            {
                                <div class="small text-muted font-monospace">@user.CompanyCode</div>
                            }
                        </td>
                        <td>
                            <span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                @(user.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>@user.CreatedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</td>
                        <td class="text-end">
                            <a asp-action="Edit"
                               asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-light">
                                Edit
                            </a>

                            @if (user.IsActive)
                            {
                                <form asp-action="Deactivate"
                                      asp-route-id="@user.Id"
                                      method="post"
                                      asp-antiforgery="true"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        Deactivate
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Activate"
                                      asp-route-id="@user.Id"
                                      method="post"
                                      asp-antiforgery="true"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        Activate
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}