@model SubsidiaryUserEditViewModel

@{
    ViewData["Title"] = "Edit Subsidiary User";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Edit Subsidiary User</h1>
        <p class="text-muted mb-0">Update user details and company assignment.</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Back to List
    </a>
</div>

@if (!Model.CompanyOptions.Any())
{
    <div class="alert alert-warning" role="alert">
        No active companies are available. Create or activate a company before updating users.
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit"
              asp-route-id="@Model.Id"
              method="post"
              asp-antiforgery="true">
            <input type="hidden" asp-for="Id" />

            <partial name="_SubsidiaryUserFields" model="Model" />

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary"
                        disabled="@(!Model.CompanyOptions.Any())">
                    Save Changes
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}