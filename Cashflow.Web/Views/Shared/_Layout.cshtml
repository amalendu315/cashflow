@using Microsoft.AspNetCore.Identity
@using Cashflow.Web.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    bool isSignedIn = SignInManager.IsSignedIn(User);
    bool isAdmin = User.IsInRole(AppRoles.Admin);
    bool isUser = User.IsInRole(AppRoles.User);

    ApplicationUser? currentUser = isSignedIn
        ? await UserManager.GetUserAsync(User)
        : null;

    string displayName = currentUser?.FullName!;
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = User.Identity?.Name ?? "User";
    }

    string email = currentUser?.Email ?? User.Identity?.Name ?? string.Empty;
    string initials = string.IsNullOrWhiteSpace(displayName)
        ? "U"
        : displayName.Trim()[0].ToString().ToUpperInvariant();

    string roleDisplay = isAdmin ? "Admin" : isUser ? "User" : "Account";

    var adminItems = new List<AppNavigationItemViewModel>
    {
        new() { Section = "Masters", Label = "Companies", IconCssClass = "bi bi-building", Controller = "CompanyMasters" },
        new() { Section = "Masters", Label = "Ledgers", IconCssClass = "bi bi-bank", Controller = "LedgerMasters" },
        new() { Section = "Masters", Label = "Vendors", IconCssClass = "bi bi-person-vcard", Controller = "VendorMasters" },
        new() { Section = "Access", Label = "Users", IconCssClass = "bi bi-people", Controller = "UserManagement" },
        new() { Section = "Requests", Label = "Review Requests", IconCssClass = "bi bi-ui-checks-grid", Controller = "AdminPaymentRequests" },
        new() { Section = "Ledger", Label = "Ledger Balances", IconCssClass = "bi bi-calculator", Controller = "LedgerBalances" },
        new() { Section = "Ledger", Label = "Ledger Report", IconCssClass = "bi bi-graph-up-arrow", Controller = "LedgerBalances", Action = "Report" }
    };

    var userItems = new List<AppNavigationItemViewModel>
    {
        new() { Section = "Requests", Label = "My Requests", IconCssClass = "bi bi-receipt", Controller = "PaymentRequests" },
        new() { Section = "Requests", Label = "New Request", IconCssClass = "bi bi-plus-circle", Controller = "PaymentRequests", Action = "Create" }
    };

    IReadOnlyList<AppNavigationItemViewModel> navItems = isAdmin
        ? adminItems
        : isUser
            ? userItems
            : new List<AppNavigationItemViewModel>();

    bool IsActive(AppNavigationItemViewModel item)
    {
        return string.Equals(currentController, item.Controller, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentAction, item.Action, StringComparison.OrdinalIgnoreCase);
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />
    <meta name="layout-test" content="main-layout-loaded" />
    <title>@ViewData["Title"] - Cashflow</title>

    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet" />
<link rel="stylesheet" href="/css/site.css" />
<link rel="stylesheet" href="/Cashflow.Web.styles.css" />
</head>
<body>
    @if (!isSignedIn)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="app-shell">
            <aside id="appSidebar" class="app-sidebar">
                <div class="app-brand">
                    <div class="app-brand-icon">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                    <div>
                        <div class="app-brand-title">Cashflow</div>
                        <div class="app-brand-subtitle">@roleDisplay Workspace</div>
                    </div>
                </div>

                <nav class="app-nav">
                    @foreach (string sectin in navItems.Select(item => item.Section).Distinct())
                    {
                        <div class="app-nav-section">@sectin</div>

                        @foreach (AppNavigationItemViewModel item in navItems.Where(item => item.Section == sectin))
                        {
                            string activeClass = IsActive(item) ? "active" : string.Empty;

                            <a asp-controller="@item.Controller"
                               asp-action="@item.Action"
                               class="app-nav-link @activeClass">
                                <i class="@item.IconCssClass"></i>
                                <span>@item.Label</span>
                            </a>
                        }
                    }
                </nav>
            </aside>

            <div class="app-main">
                <header class="app-topbar">
                    <div class="d-flex align-items-center gap-3">
                        <button type="button"
                                class="btn btn-outline-secondary d-lg-none"
                                data-sidebar-toggle>
                            <i class="bi bi-list"></i>
                        </button>

                        <div>
                            <div class="small text-muted">Current Module</div>
                            <div class="fw-semibold">@ViewData["Title"]</div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <div class="user-chip d-none d-md-flex">
                            <div class="user-avatar">@initials</div>
                            <div class="text-end">
                                <div class="fw-semibold">@displayName</div>
                                <div class="small text-muted">@email</div>
                            </div>
                        </div>

                        <form asp-area="Identity"
                              asp-page="/Account/Logout"
                              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                              method="post">
                            <button type="submit" class="btn btn-outline-secondary">
                                <i class="bi bi-box-arrow-right me-1"></i>
                                Logout
                            </button>
                        </form>
                    </div>
                </header>

                <main role="main" class="app-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"
            asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>