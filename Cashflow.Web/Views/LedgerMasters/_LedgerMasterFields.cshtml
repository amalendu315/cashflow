@model LedgerMasterFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="mb-3">
    <label asp-for="LedgerCode" class="form-label"></label>
    <input asp-for="LedgerCode" class="form-control" autocomplete="off" />
    <span asp-validation-for="LedgerCode" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="LedgerName" class="form-label"></label>
    <input asp-for="LedgerName" class="form-control" autocomplete="off" />
    <span asp-validation-for="LedgerName" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>

<div class="form-check form-switch mb-3">
    <input asp-for="IsActive" class="form-check-input" />
    <label asp-for="IsActive" class="form-check-label"></label>
</div>