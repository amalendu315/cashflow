@page
@model Cashflow.Web.Areas.Identity.Pages.Account.LoginModel

@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sign in";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card-header">
            <div class="auth-logo">
                <i class="bi bi-cash-coin"></i>
            </div>

            <h1 class="auth-title h3 mb-2">Welcome back</h1>
            <p class="auth-side-note mb-0">
                Sign in to manage payment requests, approvals, ledgers, and cashflow visibility.
            </p>
        </div>

        <div class="auth-card-body">
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent text-muted border-secondary">
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input asp-for="Input.Email"
                               class="form-control"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent text-muted border-secondary">
                            <i class="bi bi-shield-lock"></i>
                        </span>
                        <input asp-for="Input.Password"
                               class="form-control"
                               autocomplete="current-password"
                               aria-required="true"
                               placeholder="Enter your password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input"
                               asp-for="Input.RememberMe" />
                        <label class="form-check-label"
                               asp-for="Input.RememberMe">
                            Remember me
                        </label>
                    </div>
                </div>

                <button id="login-submit"
                        type="submit"
                        class="w-100 btn btn-lg btn-primary">
                    Sign in
                </button>
            </form>

            <div class="mt-4 pt-3 border-top border-secondary">
                <div class="small text-muted">
                    Accounts are created by the system administrator. Contact Accounts/Admin if you need access.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}